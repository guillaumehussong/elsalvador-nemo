# HuggingFace cache (dataset Nemotron)
HF_HOME=data/hf

# Clé APIYI (prioritaire si OPENAI_BASE_URL contient apiyi.com)
APIYI_API_KEY=

# Stage 1 — focus group (OpenAI-compat via APIYI)
OPENAI_BASE_URL=https://api.apiyi.com/v1
LLM_MODEL=claude-haiku-4-5-20251001
LLM_CLIENT=openai

# Estimation coût (USD par million de tokens, optionnel)
# LLM_INPUT_PRICE_PER_1M_USD=0.80
# LLM_OUTPUT_PRICE_PER_1M_USD=4.00

# Path Anthropic-compat (si OpenAI path échoue):
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.apiyi.com
